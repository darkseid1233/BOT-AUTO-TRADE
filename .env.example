# ─────────────────────────────────────────────────────────────────────────────
# AlpacaBot — environment variables
# Copy this file to .env and fill in your values.
# On Railway: add these in the "Variables" tab of your service.
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca credentials (REQUIRED for live paper/live trading) ─────────────────
# Get your keys at: https://app.alpaca.markets/paper-trading → API Keys
ALPACA_API_KEY_ID=your_key_id_here
ALPACA_API_SECRET_KEY=your_secret_key_here

# ── Alpaca endpoints (defaults are paper-trading) ─────────────────────────────
# ALPACA_BASE_URL=https://paper-api.alpaca.markets     # paper (default)
# ALPACA_BASE_URL=https://api.alpaca.markets           # live (real money!)
# ALPACA_DATA_URL=https://data.alpaca.markets

# ── Bot tuning ────────────────────────────────────────────────────────────────
# Starting paper balance (ignored when Alpaca is connected — real balance is used)
INITIAL_BALANCE=100000

# Watchlist — comma-separated crypto pairs (Alpaca format)
# WATCHLIST=BTC/USD,ETH/USD,SOL/USD,AVAX/USD,LINK/USD,DOGE/USD

# Scan interval (seconds) — how often the bot checks for new signals
SCAN_INTERVAL_SEC=30

# Tick interval (seconds) — how often open positions are marked-to-market
TICK_INTERVAL_SEC=10

# ── Risk management ───────────────────────────────────────────────────────────
# Fraction of balance risked per trade (stop-loss budget). 0.01 = 1%.
RISK_PER_TRADE=0.01

# Maximum number of simultaneously open positions
MAX_OPEN_TRADES=5

# Max fraction of balance a single position can use as notional. 0.2 = 20%.
MAX_NOTIONAL_PCT=0.2

# Max total exposure across all open trades. 0.6 = 60% of balance.
MAX_TOTAL_EXPOSURE_PCT=0.6

# Daily loss limit — bot auto-pauses when day loss exceeds this. 0.05 = 5%.
DAILY_MAX_LOSS_PCT=0.05

# Max drawdown stop — bot auto-pauses when equity falls this % below peak.
MAX_DRAWDOWN_STOP_PCT=0.15

# Minimum signal confidence (0-100) to open a trade
MIN_CONFIDENCE=60

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is automatically set by Railway — don't set this manually on Railway
PORT=3000
