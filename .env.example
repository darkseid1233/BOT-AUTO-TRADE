# ───────────────────────────────────────────────────────────────────────────
# AlpacaBot — environment variables
# Copy this file to .env and fill in your values.
# On Railway: add these in the "Variables" tab of your service.
# ───────────────────────────────────────────────────────────────────────────

# ── Alpaca credentials (REQUIRED for live paper/live trading) ─────────────────
ALPACA_API_KEY_ID=your_key_id_here
ALPACA_API_SECRET_KEY=your_secret_key_here

# ── Alpaca endpoints (defaults are paper-trading) ─────────────────────────────
# ALPACA_BASE_URL=https://paper-api.alpaca.markets     # paper (default)
# ALPACA_BASE_URL=https://api.alpaca.markets           # live (real money!)
# ALPACA_DATA_URL=https://data.alpaca.markets

# ── Bot tuning ────────────────────────────────────────────────────────────────────────
# Starting paper balance (ignored when Alpaca is connected — real balance is used)
INITIAL_BALANCE=100000

# Watchlist — comma-separated crypto pairs (Alpaca format)
# NOTE: MATIC/USD is DELISTED on Alpaca (migrated to POL). Use POL/USD instead,
# otherwise the bot silently falls back to SYNTHETIC data for that symbol.
# WATCHLIST=BTC/USD,ETH/USD,SOL/USD,AVAX/USD,LINK/USD,DOGE/USD,UNI/USD,POL/USD

# Scan interval (seconds) — how often the bot checks for new signals
SCAN_INTERVAL_SEC=30

# Tick interval (seconds) — how often open positions are marked-to-market
TICK_INTERVAL_SEC=10

# ── Risk management ───────────────────────────────────────────────────────────────────
# Fraction of balance risked per trade (stop-loss budget). 0.01 = 1%.
RISK_PER_TRADE=0.01

# Maximum number of simultaneously open positions
MAX_OPEN_TRADES=5

# Max fraction of balance a single position can use as notional. 0.2 = 20%.
MAX_NOTIONAL_PCT=0.2

# Max total exposure across all open trades. 0.6 = 60% of balance.
MAX_TOTAL_EXPOSURE_PCT=0.6

# Daily loss limit — bot auto-pauses when day loss exceeds this. 0.05 = 5%.
DAILY_MAX_LOSS_PCT=0.05

# Max drawdown stop — bot auto-pauses when equity falls this % below peak.
MAX_DRAWDOWN_STOP_PCT=0.15

# Minimum signal confidence (0-100) to open a trade
MIN_CONFIDENCE=60

# ── Anti-Revenge-Trading / SL cooldowns ─────────────────────────────────────
# How many minutes to block a symbol from re-entry after a stop-loss hit.
# Prevents revenge-trading (e.g. MATIC SHORT → SL → immediate SHORT again).
SL_COOLDOWN_MINUTES=30

# How many minutes to block the SAME side on a symbol from being opened again.
# Works even if the previous position was closed at TP or manually.
# Example: if MATIC SHORT was opened at 11:00, no new SHORT until 11:15.
SIGNAL_DEDUP_MINUTES=15

# ── Signal Quality & Filter Thresholds ───────────────────────────────────────
# All thresholds below are env-overridable so you can tune without code changes.
# CURRENT DEFAULTS are tuned for the June 2026 oversold bear market (F&G~12).
# Tighten them back when market recovers (F&G > 40, ADX > 25 consistently).

# ADX below this = no tradeable trend. Default 18 (was 22 — too strict for current 18.4 ADX).
# ADX_TREND_THRESHOLD=18

# RSI late-entry guard. SHORT blocked when RSI < (100 - X). Default 80 → SHORT blocked only RSI < 20.
# Was 72 → SHORT blocked at RSI < 28 which filtered ALL oversold SHORTs in bear market.
# RSI_LATE_ENTRY_GUARD=80

# Minimum relative volume (current/avg20) to confirm trade conviction.
# Default 0.35 (was 0.8 — blocked LTC/LINK at 0.12x). Set higher in normal markets.
# MIN_VOLUME_RATIO=0.35

# Minimum signal quality score (0-100) to open a trade.
# Default 58 (was 70 — too strict for bear conditions with limited signal quality).
# MIN_SIGNAL_QUALITY=58

# Fear & Greed extreme fear threshold. LONGs blocked below this value.
# Default 10 (was 20 — at F&G=12 we still want SHORT setups, not to block all longs).
# FG_EXTREME_FEAR=10

# Minimum net Risk:Reward after fees+slippage.
# Default 1.5 (was 1.8 — gives more room in low-ATR ranging conditions).
# MIN_RR_NET=1.5

# EMA50 vs EMA200 minimum spread to call a trend.
# Default 0.05% (was 0.1% — less strict, avoids blocking fresh trend beginnings).
# EMA_TREND_SPREAD_PCT=0.05

# ── Execution costs (applied to BOTH paper trading and backtests) ────────────
# Taker fee per side as a fraction of notional. 0.0004 = 0.04% (Alpaca crypto).
TAKER_FEE_PCT=0.0004
# Simulated slippage per fill as a fraction. 0.0005 = 0.05%. Exits slip AGAINST
# the position so paper results are not optimistic vs reality.
SIMULATED_SLIPPAGE_PCT=0.0005

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is automatically set by Railway — don't set this manually on Railway
PORT=3000
